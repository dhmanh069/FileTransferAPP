<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FileTransferServer.MainWindow"
        Title="File Transfer Server"
        Width="800"
        Height="600">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="10">

            <TextBlock Text="File Transfer Server"
                       FontSize="24"
                       FontWeight="Bold"/>

            <StackPanel Orientation="Horizontal"
                        Spacing="10">

                <TextBlock Text="Port:"
                           VerticalAlignment="Center"/>

                <TextBox Name="txtPort"
                         Width="100"
                         Text="5000"/>

                <Button Name="btnStart"
                        Width="120">
                    Start Server
                </Button>

            </StackPanel>

            <TextBlock Text="Online Clients"
                       FontWeight="Bold"/>

            <ListBox Name="lstClients"
                     Height="150"/>

            <TextBlock Text="Transfer History"
                       FontWeight="Bold"/>

            <ListBox Name="lstHistory"
                     Height="200"/>

            <TextBlock Text="Status"
                       FontWeight="Bold"/>

            <TextBlock Name="txtStatus"
                       Text="Server stopped"/>

        </StackPanel>
    </ScrollViewer>

</Window>